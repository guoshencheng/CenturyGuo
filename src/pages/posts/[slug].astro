---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";
import { formatDate } from "../../utils/formatDate";
import "../../styles/markdown.css";
import { extractFirstImage } from "../../utils/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, all: posts },
  }));
}

const { post, all } = Astro.props;
const { title, date, tags, description, faq } = post.data;
const { Content } = await post.render();

const tagSet = new Set(tags);
const related = all
  .filter((p) => p.slug !== post.slug)
  .map((p) => ({
    post: p,
    overlap: p.data.tags.filter((t) => tagSet.has(t)).length,
  }))
  .filter((entry) => entry.overlap > 0)
  .sort((a, b) => {
    if (b.overlap !== a.overlap) return b.overlap - a.overlap;
    return b.post.data.date.getTime() - a.post.data.date.getTime();
  })
  .slice(0, 3)
  .map((entry) => entry.post);
---

<Base
  terminalTitle={`century@blog:~/posts/${post.slug}.md`}
  seo={{
    title,
    description,
    type: "article",
    publishedTime: date,
    tags,
    image: extractFirstImage(post.body),
    body: post.body,
    faqs: post.data.faq,
    person: {
      name: "Century Guo",
      jobTitle: "全栈工程师",
      knowsAbout: ["LLM Agent", "Node", "React", "架构设计"],
      sameAs: ["https://github.com/guoshencheng"],
    },
  }}
>
  <Card prompt={`> CENTURY_GUO:/posts/${post.slug}`}>
    <article class="article">
      <header class="article-header">
        <a href={`/posts/${post.slug}`} class="article-title">
          {title}
        </a>
        <div class="article-meta">
          {formatDate(date)}
          {tags.length > 0 && (
            <span class="article-meta-tags">
              {" | "}
              {tags.map((tag) => `#${tag}`).join(" ")}
            </span>
          )}
        </div>
        {description && <p class="article-desc">{description}</p>}
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="article-tag">{tag}</a>
            ))}
          </div>
        )}
      </header>

      <div class="article-body">
        <Content />
      </div>

      {faq && faq.length > 0 && (
        <section class="article-faq">
          <h2 class="article-faq__title">常见问题</h2>
          {faq.map((item) => (
            <details class="article-faq__item" open>
              <summary class="article-faq__q">{item.q}</summary>
              <p class="article-faq__a">{item.a}</p>
            </details>
          ))}
        </section>
      )}

      {related.length > 0 && (
        <aside class="article-related">
          <h2 class="article-related__title">延伸阅读</h2>
          <ul class="article-related__list">
            {related.map((p) => (
              <li class="article-related__item">
                <a href={`/posts/${p.slug}`} class="article-related__link">
                  {p.data.title}
                </a>
                <span class="article-related__date">
                  {formatDate(p.data.date)}
                </span>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <footer class="article-footer">
        <a href="/" class="article-back">cd ~/posts/</a>
      </footer>
    </article>
  </Card>
</Base>

<style>
  .article-header {
    margin-bottom: var(--space-xl);
  }

  .article-title {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-card-bg);
    padding: 4px 14px;
    font-size: var(--text-xl);
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    line-height: 1.4;
    transition: filter 0.15s;
  }

  .article-title:hover {
    filter: brightness(1.1);
  }

  .article-meta {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-link);
    font-family: var(--font-mono);
  }

  .article-meta-tags {
    color: var(--color-link);
  }

  .article-desc {
    margin: var(--space-sm) 0 0;
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  .article-tags {
    margin-top: var(--space-sm);
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .article-tag {
    display: inline-block;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 4px 10px;
    font-size: 11px;
    color: var(--color-link);
    font-family: var(--font-mono);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .article-tag:hover {
    color: var(--color-link-hover);
    border-color: var(--color-link);
  }

  .article-body {
    margin-top: var(--space-xl);
  }

  .article-faq {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: var(--border);
  }

  .article-faq__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-md);
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .article-faq__item {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-sm);
    background: var(--color-bg);
  }

  .article-faq__item[open] {
    border-color: var(--color-link);
  }

  .article-faq__q {
    cursor: pointer;
    color: var(--color-link);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 600;
    list-style: none;
    padding: var(--space-xs) 0;
  }

  .article-faq__q::-webkit-details-marker {
    display: none;
  }

  .article-faq__q::before {
    content: "▸ ";
    color: var(--color-accent);
    display: inline-block;
    transition: transform 0.15s;
  }

  .article-faq__item[open] .article-faq__q::before {
    content: "▾ ";
  }

  .article-faq__a {
    margin: var(--space-sm) 0 0;
    padding-left: var(--space-md);
    color: var(--color-text);
    line-height: 1.7;
    border-left: 2px solid var(--color-border);
  }

  .article-related {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: var(--border);
  }

  .article-related__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-md);
    color: var(--color-text);
    font-family: var(--font-mono);
  }

  .article-related__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .article-related__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .article-related__link {
    color: var(--color-link);
    text-decoration: none;
    font-size: var(--text-base);
  }

  .article-related__link:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }

  .article-related__date {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .article-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: var(--border);
  }

  .article-back {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  @media (max-width: 640px) {
    .article-title {
      font-size: var(--text-lg);
    }
  }
</style>